<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body>
  <div class="head">
    <div class="subhead">
      <div class="name">
      </div>
      <div class="cursor">
      </div>
    </div>
    <div class="buttonDiv">
      <a href="/" ><button class="<%=page=='home' ? 'btnActive' : 'btn' %>"><span class="icon">🏠</span><span class="text">Home</span></button></a>
      <a href="/add"><button class="<%=page=='add' ? 'btnActive' : 'btn' %>"><span class="icon">🆕</span><span class="text">Add</span></button></a>

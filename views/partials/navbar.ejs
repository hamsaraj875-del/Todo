        <div>
          <a href="/add"><button class="next">Add 🆕</button></a>
        </div>
        <hr class="hr">
        <div>
          <a href="/deleteAll"><button class="next">Delete History 🗑️</button></a>
        </div>
        <hr class="hr">
        <div>
          <a href="/logout"><button class="next">Logout 🔓</button></a>
        </div>
        <hr class="hr">
      </div>
    </div>
    <hr class="mainHr">
